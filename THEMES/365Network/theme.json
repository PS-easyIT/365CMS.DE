{
  "name": "365Network",
  "slug": "365network",
  "version": "2.1.0",
  "author": "PHINIT.DE / Andreas Hepp",
  "description": "Das offizielle 365Network-Theme – professionell, charakterstark, editorial. Deep Navy + Warm Amber.",
  "tags": ["professional", "editorial", "responsive", "cms", "network", "dark-mode"],
  "supports": ["dark-mode", "custom-logo", "sticky-header", "custom-css"],

  "customization": {

    "colors": {
      "label": "Farben",
      "description": "Globale Farbpalette des Themes – Primär-, Sekundär- und Akzentfarben.",
      "settings": {
        "primary_color": {
          "label": "Primärfarbe",
          "type": "color",
          "default": "#1e3a5f",
          "description": "Hauptfarbe für Buttons, Links und Akzente"
        },
        "secondary_color": {
          "label": "Sekundärfarbe",
          "type": "color",
          "default": "#152d4a",
          "description": "Hover-Zustand von Buttons und Links"
        },
        "accent_color": {
          "label": "Akzentfarbe",
          "type": "color",
          "default": "#b45309",
          "description": "Hervorhebungen, Tags, Badges und Navigation-Akzente"
        },
        "text_color": {
          "label": "Textfarbe",
          "type": "color",
          "default": "#1c1917",
          "description": "Haupttextfarbe"
        },
        "bg_color": {
          "label": "Hintergrundfarbe",
          "type": "color",
          "default": "#faf9f7",
          "description": "Seitenhintergrund (warmes Off-White)"
        },
        "link_color": {
          "label": "Linkfarbe",
          "type": "color",
          "default": "#b45309",
          "description": "Standard-Linkfarbe im Content"
        },
        "link_hover_color": {
          "label": "Link Hover-Farbe",
          "type": "color",
          "default": "#b45309",
          "description": "Linkfarbe beim Hover-Zustand"
        },
        "muted_color": {
          "label": "Gedämpfte Textfarbe",
          "type": "color",
          "default": "#78716c",
          "description": "Sekundärer, schwächerer Text (Meta-Infos etc.)"
        },
        "border_color": {
          "label": "Rahmenfarbe",
          "type": "color",
          "default": "#e7e5e4",
          "description": "Standard-Rahmenfarbe für Trennlinien und Cards"
        },
        "success_color": {
          "label": "Erfolgsfarbe",
          "type": "color",
          "default": "#22c55e",
          "description": "Positivmeldungen und Status-Badges"
        },
        "error_color": {
          "label": "Fehlerfarbe",
          "type": "color",
          "default": "#ef4444",
          "description": "Fehlermeldungen und Warnungen"
        }
      }
    },

    "typography": {
      "label": "Typografie",
      "description": "Schriftarten, -größen und Zeilenhöhe für Text und Überschriften.",
      "settings": {
        "font_family_base": {
          "label": "Basis-Schriftart",
          "type": "select",
          "options": {
            "system": "System-Standard",
            "inter": "Inter",
            "roboto": "Roboto",
            "open-sans": "Open Sans",
            "lato": "Lato",
            "montserrat": "Montserrat",
            "poppins": "Poppins",
            "raleway": "Raleway"
          },
          "default": "inter",
          "description": "Schriftart für Fließtext"
        },
        "font_family_heading": {
          "label": "Überschriften-Schriftart",
          "type": "select",
          "options": {
            "system": "System-Standard",
            "georgia": "Georgia (Serif)",
            "inter": "Inter",
            "roboto": "Roboto",
            "open-sans": "Open Sans",
            "lato": "Lato",
            "montserrat": "Montserrat",
            "poppins": "Poppins",
            "raleway": "Raleway"
          },
          "default": "georgia",
          "description": "Schriftart für Überschriften"
        },
        "font_size_base": {
          "label": "Basis-Schriftgröße (px)",
          "type": "number",
          "default": 16,
          "min": 12,
          "max": 24,
          "description": "Schriftgröße des Fließtexts in Pixeln"
        },
        "line_height_base": {
          "label": "Zeilenhöhe",
          "type": "number",
          "default": 1.6,
          "min": 1.2,
          "max": 2.5,
          "step": 0.1,
          "description": "Zeilenhöhe des Fließtexts (Faktor)"
        },
        "font_weight_heading": {
          "label": "Überschriften-Gewicht",
          "type": "select",
          "options": {
            "400": "Regular (400)",
            "500": "Medium (500)",
            "600": "Semi-Bold (600)",
            "700": "Bold (700)",
            "800": "Extra-Bold (800)",
            "900": "Black (900)"
          },
          "default": "700",
          "description": "Font-Weight für alle Überschriften"
        }
      }
    },

    "layout": {
      "label": "Layout",
      "description": "Containerbreite, Abstände, Eckenradius und strukturelle Layout-Optionen.",
      "settings": {
        "container_width": {
          "label": "Container-Breite (px)",
          "type": "number",
          "default": 1200,
          "min": 800,
          "max": 1920,
          "description": "Maximale Breite des Inhaltsbereichs in Pixeln"
        },
        "content_padding": {
          "label": "Content-Padding (rem)",
          "type": "number",
          "default": 2,
          "min": 0.5,
          "max": 6,
          "step": 0.25,
          "description": "Horizontaler Innenabstand des Containers"
        },
        "border_radius": {
          "label": "Eckenradius (px)",
          "type": "number",
          "default": 8,
          "min": 0,
          "max": 32,
          "description": "Standard-Rundung für Cards, Buttons und Felder"
        },
        "section_spacing": {
          "label": "Sektionsabstand (rem)",
          "type": "number",
          "default": 4,
          "min": 1,
          "max": 12,
          "step": 0.5,
          "description": "Vertikaler Abstand zwischen Seitenbereichen"
        },
        "enable_sticky_header": {
          "label": "Sticky Header aktivieren",
          "type": "checkbox",
          "default": true,
          "description": "Header bleibt beim Scrollen oben fixiert"
        }
      }
    },

    "header": {
      "label": "Header",
      "description": "Farben, Höhe und Verhalten der Navigationsleiste.",
      "settings": {
        "logo_url": {
          "label": "Header Logo",
          "type": "image",
          "default": "",
          "description": "Logo-Bild im Header (JPG, PNG, WebP, SVG – max. 2 MB). Leer lassen für Standard-Icon."
        },
        "header_bg_color": {
          "label": "Header-Hintergrund",
          "type": "color",
          "default": "#ffffff",
          "description": "Hintergrundfarbe der Navigationsleiste"
        },
        "header_text_color": {
          "label": "Header-Textfarbe",
          "type": "color",
          "default": "#1c1917",
          "description": "Farbe von Navigationslinks und Logo-Text"
        },
        "header_height": {
          "label": "Header-Höhe (px)",
          "type": "number",
          "default": 72,
          "min": 48,
          "max": 120,
          "description": "Höhe der Navigationsleiste"
        },
        "logo_max_height": {
          "label": "Logo-Maximalhöhe (px)",
          "type": "number",
          "default": 48,
          "min": 24,
          "max": 100,
          "description": "Maximale Höhe des Site-Logos"
        },
        "show_header_shadow": {
          "label": "Header-Schatten anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Schatten unterhalb der Navigationsleiste"
        }
      }
    },

    "footer": {
      "label": "Footer",
      "description": "Hintergrund- und Textfarben des Footerbereichs sowie Inhalte.",
      "settings": {
        "footer_bg_color": {
          "label": "Footer-Hintergrund",
          "type": "color",
          "default": "#1c1917",
          "description": "Hintergrundfarbe des Footers"
        },
        "footer_text_color": {
          "label": "Footer-Textfarbe",
          "type": "color",
          "default": "#a8a29e",
          "description": "Textfarbe im Footer-Bereich"
        },
        "footer_link_color": {
          "label": "Footer-Linkfarbe",
          "type": "color",
          "default": "#e7e5e4",
          "description": "Farbe der Links im Footer"
        },
        "footer_text": {
          "label": "Footer-Beschreibungstext",
          "type": "textarea",
          "default": "Die IT-Networking-Plattform für Experten, Unternehmen und Events. Vernetze dich mit der IT-Community.",
          "description": "Text im ersten Widget-Bereich (z.B. Firmenbeschreibung)"
        },
        "show_network_widgets": {
          "label": "Netzwerk-Widgets anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Aktiviert den oberen Footer-Bereich mit Experten/Unternehmen-Links (spezifisch für IT Network)"
        },
        "copyright_text": {
          "label": "Copyright-Text",
          "type": "text",
          "default": "&copy; {year} {site_title}. Alle Rechte vorbehalten.",
          "description": "Copyright-Zeile unten. Platzhalter: {year}, {site_title}. HINWEIS: Entfernen des Copyrights ist nur mit gültiger Lizenz erlaubt (Autor: Andreas Hepp | PhinIT.DE)."
        }
      }
    },

    "buttons": {
      "label": "Buttons",
      "description": "Eckenradius, Padding, Schriftgewicht und Textstil aller Buttons.",
      "settings": {
        "button_border_radius": {
          "label": "Button-Eckenradius (px)",
          "type": "number",
          "default": 6,
          "min": 0,
          "max": 50,
          "description": "Eckenrundung aller regulären Buttons"
        },
        "button_padding_x": {
          "label": "Button-Padding horizontal (rem)",
          "type": "number",
          "default": 1.5,
          "min": 0.5,
          "max": 4,
          "step": 0.25,
          "description": "Horizontaler Innenabstand der Buttons"
        },
        "button_padding_y": {
          "label": "Button-Padding vertikal (rem)",
          "type": "number",
          "default": 0.625,
          "min": 0.25,
          "max": 2,
          "step": 0.125,
          "description": "Vertikaler Innenabstand der Buttons"
        },
        "button_font_weight": {
          "label": "Button-Schriftgewicht",
          "type": "select",
          "options": {
            "400": "Regular (400)",
            "500": "Medium (500)",
            "600": "Semi-Bold (600)",
            "700": "Bold (700)"
          },
          "default": "600",
          "description": "Schriftgewicht aller Buttons"
        },
        "button_transform": {
          "label": "Button-Textumwandlung",
          "type": "select",
          "options": {
            "none": "Normal",
            "uppercase": "GROSSBUCHSTABEN",
            "capitalize": "Erster Buchstabe groß"
          },
          "default": "none",
          "description": "Textformatierung für Button-Beschriftungen"
        }
      }
    },

    "advanced": {
      "label": "Erweitert",
      "description": "Eigenes CSS, das am Ende aller Theme-Styles eingefügt wird.",
      "settings": {
        "custom_css": {
          "label": "Eigenes CSS",
          "type": "textarea",
          "default": "",
          "description": "Zusätzliches CSS, das am Ende aller Theme-Styles angehängt wird. Überschreibt beliebige Stile."
        }
      }
    }

  }
}
