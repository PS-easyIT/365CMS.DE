        "emergency_phone": {
          "label": "Notfall-Rufnummer",
          "type": "text",
          "default": "112",
          "description": "Notfall-Telefonnummer (z.B. 112 oder Praxis-Notfall)"
        },
        "emergency_banner_text": {
          "label": "Notfall-Banner Text",
          "type": "text",
          "default": "Notfall? Bitte rufen Sie sofort an:",
          "description": "Text im Notfall-Banner vor der Rufnummer"
        },
        "appointment_phone": {
          "label": "Termin-Telefonnummer",
          "type": "text",
          "default": "",
          "description": "Telefonnummer für Terminvereinbarungen im Header"
        }
      }
    },

    "footer": {
      "label": "Footer",
      "description": "Footer mit medizinischen Pflichtangaben und Datenschutzhinweisen.",
      "settings": {
        "footer_bg_color": {
          "label": "Footer-Hintergrund",
          "type": "color",
          "default": "#0c4a6e",
          "description": "Dunkles Blau für seriösen Abschluss"
