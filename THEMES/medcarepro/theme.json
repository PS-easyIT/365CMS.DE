          "default": "Ihre Gesundheit ist unsere Priorität. Kompetente medizinische Versorgung mit modernsten Methoden und einfühlsamer Betreuung.",
          "description": "Praxis-/Klinik-Beschreibung im Footer"
        },
        "footer_disclaimer": {
          "label": "Medizinischer Disclaimer",
          "type": "textarea",
          "default": "Die Inhalte dieser Website dienen ausschließlich der allgemeinen Information. Sie ersetzen keine professionelle medizinische Beratung, Diagnose oder Behandlung.",
          "description": "Pflicht-Disclaimer für medizinische Websites"
        },
        "copyright_text": {
          "label": "Copyright-Text",
          "type": "text",
          "default": "&copy; {year} {site_title}. Alle Rechte vorbehalten.",
          "description": "Copyright-Zeile. Platzhalter: {year}, {site_title}"
        }
      }
    },

    "buttons": {
      "label": "Buttons",
      "description": "Zugängliche, gut klickbare Buttons für alle Altersgruppen.",
      "settings": {
        "button_border_radius": {
          "label": "Button-Eckenradius (px)",
          "type": "number",
          "default": 8,
          "min": 0,
          "max": 50
        },
        "button_padding_x": {
          "label": "Button-Padding horizontal (rem)",
          "type": "number",
          "default": 2,
          "min": 0.5,
          "max": 4,
          "step": 0.25,
          "description": "Großzügiges Padding für Touch-Bedienung"
        },
        "button_padding_y": {
          "label": "Button-Padding vertikal (rem)",
          "type": "number",
          "default": 0.875,
          "min": 0.25,
          "max": 2,
          "step": 0.125,
          "description": "Höherer Button für Touch-Komfort"
        },
        "button_font_weight": {
          "label": "Button-Schriftgewicht",
          "type": "select",
          "options": {
            "600": "Semi-Bold (600) – Standard",
            "700": "Bold (700)"
          },
          "default": "600"
        },
        "button_transform": {
          "label": "Button-Text",
          "type": "select",
          "options": {
            "none": "Normal – Standard",
            "capitalize": "Erster Buchstabe groß"
          },
          "default": "none"
        }
      }
    },

