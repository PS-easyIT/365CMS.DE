        },
        "cookie_banner_text": {
          "label": "Cookie-Banner Text",
          "type": "textarea",
          "default": "Diese Website verwendet ausschließlich technisch notwendige Cookies. Eine Verarbeitung personenbezogener Daten erfolgt nur nach ausdrücklicher Einwilligung.",
          "description": "Text im Cookie-Consent-Banner"
        },
        "show_privacy_on_forms": {
          "label": "Datenschutz-Hinweis auf Formularen",
