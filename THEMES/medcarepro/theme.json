    "dsgvo_medical": {
      "label": "DSGVO & Datenschutz",
      "description": "Datenschutz-Einstellungen speziell für medizinische Websites (verschärfte Anforderungen).",
      "settings": {
        "enable_medical_dsgvo_mode": {
          "label": "Medizinischer DSGVO-Modus",
