{
  "name": "MedCare Pro",
  "slug": "medcarepro",
  "version": "1.0.1",

  "templates": {
    "home":         "home.php",
    "index":        "index.php",
    "page":         "page.php",
    "404":          "404.php",
    "error":        "error.php",
    "blog":         "blog.php",
    "blog-single":  "blog-single.php",
    "search":       "search.php",
    "login":        "login.php",
    "register":     "register.php"
  },
  "author": "PHINIT.DE / Andreas Hepp",
  "description": "Gesundheitswesen & Medizin Theme – Vertrauensvoll, beruhigend, klar. Für Arztpraxen, Kliniken, Therapeuten und Pflegedienste.",
  "tags": ["medizin", "gesundheit", "arzt", "klinik", "dsgvo", "barrierefrei", "cms"],
  "supports": ["dark-mode", "custom-logo", "sticky-header", "custom-css", "booking", "accessibility", "dsgvo-medical"],

  "customization": {

    "colors": {
      "label": "Farben",
      "description": "Beruhigende Farbpalette – helles Blau für Vertrauen, viel Weißraum.",
      "settings": {
        "primary_color": {
          "label": "Primärfarbe",
          "type": "color",
          "default": "#0ea5e9",
          "description": "Helles Blau – Reinheit und Vertrauen"
        },
        "secondary_color": {
          "label": "Sekundärfarbe",
          "type": "color",
          "default": "#0284c7",
          "description": "Mittleres Blau für Hover-Zustände"
        },
        "accent_color": {
          "label": "Akzentfarbe",
          "type": "color",
          "default": "#10b981",
          "description": "Grün für Gesundheit, Erfolg und positive Befunde"
        },
        "warning_color": {
          "label": "Warnfarbe",
          "type": "color",
          "default": "#f59e0b",
          "description": "Amber für Hinweise und Warnungen"
        },
        "urgent_color": {
          "label": "Dringend-Farbe",
          "type": "color",
          "default": "#ef4444",
          "description": "Rot für Notfälle und kritische Hinweise"
        },
        "specialty_general": {
          "label": "Fachbereich: Allgemein",
          "type": "color",
          "default": "#0ea5e9",
          "description": "Farbe für Allgemeinmedizin-Badges"
        },
        "specialty_dental": {
          "label": "Fachbereich: Zahnmedizin",
          "type": "color",
          "default": "#f59e0b",
          "description": "Farbe für Zahnmedizin-Badges"
        },
        "specialty_surgery": {
          "label": "Fachbereich: Chirurgie",
          "type": "color",
          "default": "#8b5cf6",
          "description": "Farbe für Chirurgie-Badges"
        },
        "specialty_therapy": {
          "label": "Fachbereich: Therapie",
          "type": "color",
          "default": "#10b981",
          "description": "Farbe für Therapie-Badges"
        },
        "text_color": {
          "label": "Textfarbe",
          "type": "color",
          "default": "#0f172a",
          "description": "Klare, gut lesbare Textfarbe"
        },
        "bg_color": {
          "label": "Hintergrundfarbe",
          "type": "color",
          "default": "#f0f9ff",
          "description": "Sehr helles Blau-Weiß – sauber und klinisch"
        },
        "card_bg_color": {
          "label": "Card-Hintergrundfarbe",
          "type": "color",
          "default": "#ffffff",
          "description": "Reines Weiß für Cards"
        },
        "link_color": {
          "label": "Linkfarbe",
          "type": "color",
          "default": "#0284c7",
          "description": "Mittelblau für Links"
        },
        "muted_color": {
          "label": "Gedämpfte Textfarbe",
          "type": "color",
          "default": "#64748b",
          "description": "Sekundärer Text für Labels und Meta-Infos"
        },
        "border_color": {
          "label": "Rahmenfarbe",
          "type": "color",
          "default": "#bae6fd",
          "description": "Zartes Hellblau für Rahmen"
        }
      }
    },

    "typography": {
      "label": "Typografie",
      "description": "Autoritative, sehr gut lesbare Schriften für medizinische Fachtexte.",
      "settings": {
        "font_family_base": {
          "label": "Basis-Schriftart",
          "type": "select",
          "options": {
            "open-sans": "Open Sans (empfohlen – maximale Lesbarkeit)",
            "roboto": "Roboto",
            "lato": "Lato",
            "inter": "Inter",
            "source-sans-pro": "Source Sans Pro"
          },
          "default": "open-sans",
          "description": "Maximale Lesbarkeit für Patienteninformationen"
        },
        "font_family_heading": {
          "label": "Überschriften-Schriftart",
          "type": "select",
          "options": {
            "source-sans-pro": "Source Sans Pro (empfohlen – professionell)",
            "libre-baskerville": "Libre Baskerville (Serife – Autorität)",
            "open-sans": "Open Sans",
            "lato": "Lato",
            "roboto": "Roboto"
          },
          "default": "source-sans-pro",
          "description": "Professionelle Schrift für medizinische Autorität"
        },
        "font_family_medical_text": {
          "label": "Medizinischer Fachtext Schriftart",
          "type": "select",
          "options": {
            "source-serif-pro": "Source Serif Pro (empfohlen – vertrauenswürdig)",
            "georgia": "Georgia",
            "libre-baskerville": "Libre Baskerville"
          },
          "default": "source-serif-pro",
          "description": "Serifen-Schrift für Diagnose- und Befundtexte"
        },
        "font_size_base": {
          "label": "Basis-Schriftgröße (px)",
          "type": "number",
          "default": 17,
          "min": 14,
          "max": 24,
          "description": "Größere Schrift für Barrierefreiheit und ältere Patienten"
        },
        "line_height_base": {
          "label": "Zeilenhöhe",
          "type": "number",
          "default": 1.75,
          "min": 1.2,
          "max": 2.5,
          "step": 0.1,
          "description": "Großzügige Zeilenhöhe für medizinische Texte"
        },
        "font_weight_heading": {
          "label": "Überschriften-Gewicht",
          "type": "select",
          "options": {
            "600": "Semi-Bold (600) – Standard",
            "700": "Bold (700)"
          },
          "default": "600",
          "description": "Semi-Bold für professionelle, aber zugängliche Wirkung"
        }
      }
    },

    "layout": {
      "label": "Layout",
      "description": "Viel Weißraum für beruhigende, klare Darstellung.",
      "settings": {
        "container_width": {
          "label": "Container-Breite (px)",
          "type": "number",
          "default": 1100,
          "min": 800,
          "max": 1400,
          "description": "Schmalerer Container für bessere Lesbarkeit"
        },
        "content_padding": {
          "label": "Content-Padding (rem)",
          "type": "number",
          "default": 2.5,
          "min": 0.5,
          "max": 6,
          "step": 0.25
        },
        "border_radius": {
          "label": "Eckenradius (px)",
          "type": "number",
          "default": 10,
          "min": 0,
          "max": 24,
          "description": "Sanft gerundete Kanten für beruhigende Wirkung"
        },
        "section_spacing": {
          "label": "Sektionsabstand (rem)",
          "type": "number",
          "default": 5,
          "min": 1,
          "max": 12,
          "step": 0.5,
          "description": "Großzügiger Weißraum zwischen Bereichen"
        },
        "enable_sticky_header": {
          "label": "Sticky Header",
          "type": "checkbox",
          "default": true
        },
        "enable_accessibility_toolbar": {
          "label": "Barrierefreiheits-Toolbar",
          "type": "checkbox",
          "default": true,
          "description": "Toolbar für Schriftgröße, Kontrast und Leseassistenz"
        }
      }
    },

    "header": {
      "label": "Header",
      "description": "Heller, vertrauenswürdiger Header mit optionalem Notfall-Banner.",
      "settings": {
        "logo_url": {
          "label": "Header Logo / Praxis-Logo",
          "type": "image",
          "default": "",
          "description": "Praxis- oder Klinik-Logo im Header"
        },
        "header_bg_color": {
          "label": "Header-Hintergrund",
          "type": "color",
          "default": "#ffffff",
          "description": "Weißer Header – sauber und klinisch"
        },
        "header_text_color": {
          "label": "Header-Textfarbe",
          "type": "color",
          "default": "#0f172a",
          "description": "Dunkle Textfarbe für hellen Header"
        },
        "header_border_color": {
          "label": "Header Trennlinie",
          "type": "color",
          "default": "#bae6fd",
          "description": "Dezente Trennlinie unter dem Header"
        },
        "header_height": {
          "label": "Header-Höhe (px)",
          "type": "number",
          "default": 76,
          "min": 48,
          "max": 120
        },
        "logo_max_height": {
          "label": "Logo-Maximalhöhe (px)",
          "type": "number",
          "default": 52,
          "min": 24,
          "max": 100
