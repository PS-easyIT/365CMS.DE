{
  "name": "Academy365",
  "slug": "academy365",
  "version": "1.0.0",
  "author": "PHINIT.DE / Andreas Hepp",
  "description": "Bildung & Weiterbildung Theme – Inspirierend, motivierend, modern. Für Weiterbildungsinstitute, Hochschulen und E-Learning-Anbieter.",
  "tags": ["bildung", "elearning", "kurse", "hochschule", "coaching", "responsive", "cms"],
  "supports": ["dark-mode", "custom-logo", "sticky-header", "custom-css", "lms", "certificates", "progress-tracking"],

  "customization": {

    "colors": {
      "label": "Farben",
      "description": "Inspirierende Farbpalette – Violett für Wissen, lebendig und motivierend.",
      "settings": {
        "primary_color": {
          "label": "Primärfarbe",
          "type": "color",
          "default": "#7c3aed",
          "description": "Violett – Kreativität, Wissen und Weiterbildung"
        },
        "secondary_color": {
          "label": "Sekundärfarbe",
          "type": "color",
          "default": "#5b21b6",
          "description": "Dunkleres Violett für Hover-Zustände"
        },
        "accent_color": {
          "label": "Akzentfarbe",
          "type": "color",
          "default": "#f59e0b",
          "description": "Gold/Amber für Zertifikate, Auszeichnungen und Highlights"
        },
        "success_color": {
          "label": "Erfolgsfarbe / Kurs abgeschlossen",
          "type": "color",
          "default": "#10b981",
          "description": "Grün für abgeschlossene Kurse und Zertifikate"
        },
        "progress_color": {
          "label": "Fortschritts-Farbe",
          "type": "color",
          "default": "#3b82f6",
          "description": "Blau für laufende Kurse und Fortschrittsbalken"
        },
        "category_tech": {
          "label": "Kategorie: Technologie",
          "type": "color",
          "default": "#0ea5e9",
          "description": "Farbe für Technologie-Kurskategorien"
        },
        "category_business": {
          "label": "Kategorie: Business",
          "type": "color",
          "default": "#059669",
          "description": "Farbe für Business-Kurskategorien"
        },
        "category_design": {
          "label": "Kategorie: Design",
          "type": "color",
          "default": "#ec4899",
          "description": "Farbe für Design-Kurskategorien"
        },
        "category_language": {
          "label": "Kategorie: Sprachen",
          "type": "color",
          "default": "#f59e0b",
          "description": "Farbe für Sprachkurs-Kategorien"
        },
        "text_color": {
          "label": "Textfarbe",
          "type": "color",
          "default": "#1e1b4b",
          "description": "Tiefes Indigo-Schwarz für Text"
        },
        "bg_color": {
          "label": "Hintergrundfarbe",
          "type": "color",
          "default": "#faf5ff",
          "description": "Zartes Violett-Weiß als Hintergrund"
        },
        "card_bg_color": {
          "label": "Card-Hintergrundfarbe",
          "type": "color",
          "default": "#ffffff",
          "description": "Weißer Hintergrund für Kurs-Cards"
        },
        "dark_bg_color": {
          "label": "Dark-Mode Hintergrund",
          "type": "color",
          "default": "#1e1b4b",
          "description": "Tiefes Indigo für Dark-Mode"
        },
        "link_color": {
          "label": "Linkfarbe",
          "type": "color",
          "default": "#7c3aed",
          "description": "Violett für Links"
        },
        "muted_color": {
          "label": "Gedämpfte Textfarbe",
          "type": "color",
          "default": "#6b7280",
          "description": "Sekundärer Text"
        },
        "border_color": {
          "label": "Rahmenfarbe",
          "type": "color",
          "default": "#e9d5ff",
          "description": "Zartes Violett für Rahmen"
        }
      }
    },

    "typography": {
      "label": "Typografie",
      "description": "Moderne, ansprechende Schriften für Bildungsinhalte.",
      "settings": {
        "font_family_base": {
          "label": "Basis-Schriftart",
          "type": "select",
          "options": {
            "open-sans": "Open Sans (empfohlen – gut lesbar für Kursinhalte)",
            "inter": "Inter",
            "lato": "Lato",
            "nunito-sans": "Nunito Sans"
          },
          "default": "open-sans",
          "description": "Lesbare Schrift für Kursbeschreibungen"
        },
        "font_family_heading": {
          "label": "Überschriften-Schriftart",
          "type": "select",
          "options": {
            "raleway": "Raleway (empfohlen – modern und inspirierend)",
            "poppins": "Poppins",
            "nunito": "Nunito",
            "montserrat": "Montserrat",
            "inter": "Inter"
          },
          "default": "raleway",
          "description": "Moderne Schrift für Überschriften und Kurs-Titel"
        },
        "font_family_display": {
          "label": "Display-Schriftart (Hero)",
          "type": "select",
          "options": {
            "plus-jakarta-sans": "Plus Jakarta Sans (empfohlen – bold und modern)",
            "raleway": "Raleway",
            "poppins": "Poppins",
            "montserrat": "Montserrat"
          },
          "default": "plus-jakarta-sans",
          "description": "Schrift für große Hero-Überschriften"
        },
        "font_size_base": {
          "label": "Basis-Schriftgröße (px)",
          "type": "number",
          "default": 16,
          "min": 12,
          "max": 24
        },
        "line_height_base": {
          "label": "Zeilenhöhe",
          "type": "number",
          "default": 1.7,
          "min": 1.2,
          "max": 2.5,
          "step": 0.1,
          "description": "Gute Lesbarkeit für längere Kursbeschreibungen"
        },
        "font_weight_heading": {
          "label": "Überschriften-Gewicht",
          "type": "select",
          "options": {
            "600": "Semi-Bold (600)",
            "700": "Bold (700) – Standard",
            "800": "Extra-Bold (800)"
          },
          "default": "700"
        }
      }
    },

    "layout": {
      "label": "Layout",
      "description": "Kurs-optimiertes Layout mit Grid-Darstellungen.",
      "settings": {
        "container_width": {
          "label": "Container-Breite (px)",
          "type": "number",
          "default": 1240,
          "min": 800,
          "max": 1920
        },
        "content_padding": {
          "label": "Content-Padding (rem)",
          "type": "number",
          "default": 2,
          "min": 0.5,
          "max": 6,
          "step": 0.25
        },
        "border_radius": {
          "label": "Eckenradius (px)",
          "type": "number",
          "default": 12,
          "min": 0,
          "max": 32,
          "description": "Freundlich gerundete Kanten für Kurs-Cards"
        },
        "section_spacing": {
          "label": "Sektionsabstand (rem)",
          "type": "number",
          "default": 4.5,
          "min": 1,
          "max": 12,
          "step": 0.5
        },
        "enable_sticky_header": {
          "label": "Sticky Header",
          "type": "checkbox",
          "default": true
        },
        "course_grid_columns": {
          "label": "Kurs-Grid Spalten",
          "type": "select",
          "options": {
            "2": "2 Spalten",
            "3": "3 Spalten – Standard",
            "4": "4 Spalten"
          },
          "default": "3",
          "description": "Anzahl Spalten im Kurs-Katalog-Grid"
        },
        "show_progress_bars": {
          "label": "Fortschrittsbalken anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Kurs-Fortschrittsbalken in Kurs-Cards und Dashboard"
        }
      }
    },

    "header": {
      "label": "Header",
      "description": "Moderner Header mit Kurs-Suche und Kategorie-Navigation.",
      "settings": {
        "logo_url": {
          "label": "Header Logo",
          "type": "image",
          "default": "",
          "description": "Logo im Header"
        },
        "header_bg_color": {
          "label": "Header-Hintergrund",
          "type": "color",
          "default": "#1e1b4b",
          "description": "Tiefes Indigo für akademischen Stil"
        },
        "header_text_color": {
          "label": "Header-Textfarbe",
          "type": "color",
          "default": "#ede9fe",
          "description": "Zartes Violett-Weiß"
        },
        "header_height": {
          "label": "Header-Höhe (px)",
          "type": "number",
          "default": 72,
          "min": 48,
          "max": 120
        },
        "logo_max_height": {
          "label": "Logo-Maximalhöhe (px)",
          "type": "number",
          "default": 44,
          "min": 24,
          "max": 100
        },
        "show_header_shadow": {
          "label": "Header-Schatten",
          "type": "checkbox",
          "default": true
        },
        "show_category_nav": {
          "label": "Kategorie-Navigation anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Zweite Navigationszeile mit Kurs-Kategorien"
        }
      }
    },

    "footer": {
      "label": "Footer",
      "description": "Footer mit Kurs-Kategorien, Referenzen und Akkreditierungen.",
      "settings": {
        "footer_bg_color": {
          "label": "Footer-Hintergrund",
          "type": "color",
          "default": "#1e1b4b",
          "description": "Tiefes Indigo passend zum Header"
        },
        "footer_text_color": {
          "label": "Footer-Textfarbe",
          "type": "color",
          "default": "#c4b5fd",
          "description": "Zartes Violett"
        },
        "footer_link_color": {
          "label": "Footer-Linkfarbe",
          "type": "color",
          "default": "#ede9fe",
          "description": "Helles Violett-Weiß für Links"
        },
        "footer_text": {
          "label": "Footer-Beschreibung",
          "type": "textarea",
          "default": "Ihre Plattform für berufliche Weiterbildung, anerkannte Zertifizierungen und inspirierende Lernprogramme. Lernen ohne Grenzen.",
          "description": "Instituts-Beschreibung im Footer"
        },
        "show_accreditations": {
          "label": "Akkreditierungs-Logos anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Bereich für Qualitätssiegel und Akkreditierungen im Footer"
        },
        "copyright_text": {
          "label": "Copyright-Text",
          "type": "text",
          "default": "&copy; {year} {site_title}. Alle Rechte vorbehalten.",
          "description": "Copyright-Zeile. Platzhalter: {year}, {site_title}"
        }
      }
    },

    "buttons": {
      "label": "Buttons",
      "description": "Motivierende, klickfreudige Buttons.",
      "settings": {
        "button_border_radius": {
          "label": "Button-Eckenradius (px)",
          "type": "number",
          "default": 8,
          "min": 0,
          "max": 50
        },
        "button_padding_x": {
          "label": "Button-Padding horizontal (rem)",
          "type": "number",
          "default": 1.75,
          "min": 0.5,
          "max": 4,
          "step": 0.25
        },
        "button_padding_y": {
          "label": "Button-Padding vertikal (rem)",
          "type": "number",
          "default": 0.75,
          "min": 0.25,
          "max": 2,
          "step": 0.125
        },
        "button_font_weight": {
          "label": "Button-Schriftgewicht",
          "type": "select",
          "options": {
            "600": "Semi-Bold (600)",
            "700": "Bold (700) – Standard"
          },
          "default": "700"
        },
        "button_transform": {
          "label": "Button-Text",
          "type": "select",
          "options": {
            "none": "Normal – Standard",
            "capitalize": "Erster Buchstabe groß"
          },
          "default": "none"
        }
      }
    },

    "learning_hero": {
      "label": "Hero-Bereich",
      "description": "Texte für den Lernplattform-Einstiegsbereich.",
      "settings": {
        "hero_badge": {
          "label": "Hero Badge",
          "type": "text",
          "default": "🎓 Deine Weiterbildungsplattform",
          "description": "Badge über dem Haupttitel"
        },
        "hero_headline": {
          "label": "Hero Hauptüberschrift",
          "type": "text",
          "default": "Lerne. Wachse. Zertifiziere Dich.",
          "description": "Haupttitel des Hero-Bereichs"
        },
        "hero_subline": {
          "label": "Hero Untertitel",
          "type": "textarea",
          "default": "Entdecke hunderte von Kursen, Seminaren und Zertifizierungsprogrammen. Von Experten entwickelt, anerkannt von der Industrie.",
          "description": "Beschreibungstext im Hero-Bereich"
        },
        "hero_cta_courses": {
          "label": "CTA: Kurse entdecken",
          "type": "text",
          "default": "Kurskatalog entdecken",
          "description": "Text des Kurs-Entdecken-Buttons"
        },
        "hero_cta_start": {
          "label": "CTA: Jetzt starten",
          "type": "text",
          "default": "Kostenlos starten",
          "description": "Text des Registrierungs-Buttons"
        },
        "hero_stat_courses": {
          "label": "Statistik: Kurse Label",
          "type": "text",
          "default": "Kurse",
          "description": "Label für Kurs-Anzahl-Statistik im Hero"
        },
        "hero_stat_students": {
          "label": "Statistik: Lernende Label",
          "type": "text",
          "default": "Lernende",
          "description": "Label für Teilnehmer-Anzahl-Statistik"
        },
        "hero_stat_tutors": {
          "label": "Statistik: Dozenten Label",
          "type": "text",
          "default": "Dozenten",
          "description": "Label für Dozenten-Anzahl-Statistik"
        }
      }
    },

    "learning_courses": {
      "label": "Kurs-Darstellung",
      "description": "Einstellungen für Kurs-Cards, Katalog und Lernfortschritt.",
      "settings": {
        "course_catalog_title": {
          "label": "Kurskatalog Titel",
          "type": "text",
          "default": "Alle Kurse & Seminare",
          "description": "Überschrift des Kurs-Katalogs"
        },
        "featured_courses_title": {
          "label": "Empfohlene Kurse Titel",
          "type": "text",
          "default": "Empfohlene Kurse",
          "description": "Überschrift der Featured-Kurse-Sektion"
        },
        "new_courses_title": {
          "label": "Neue Kurse Titel",
          "type": "text",
          "default": "Neu eingetroffen",
          "description": "Überschrift der neuen Kurse"
        },
        "show_course_rating": {
          "label": "Kurs-Bewertungen anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Sternebewertung auf Kurs-Cards"
        },
        "show_participant_count": {
          "label": "Teilnehmerzahl anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Anzahl Teilnehmer auf Kurs-Cards"
        },
        "show_duration": {
          "label": "Kursdauer anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Geschätzte Lernzeit auf Kurs-Cards"
        },
        "show_certificate_badge": {
          "label": "Zertifikat-Badge anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Zertifikat-Badge bei zertifizierten Kursen"
        },
        "free_label": {
          "label": "Kostenlos-Label",
          "type": "text",
          "default": "Kostenlos",
          "description": "Badge-Text für kostenlose Kurse"
        },
        "certificate_label": {
          "label": "Zertifikat-Label",
          "type": "text",
          "default": "Mit Zertifikat",
          "description": "Badge-Text für zertifizierte Kurse"
        },
        "new_badge_label": {
          "label": "Neu-Badge Label",
          "type": "text",
          "default": "Neu",
          "description": "Badge-Text für neue Kurse"
        },
        "bestseller_label": {
          "label": "Bestseller-Label",
          "type": "text",
          "default": "Bestseller",
          "description": "Badge-Text für beliebteste Kurse"
        }
      }
    },

    "learning_content": {
      "label": "Seiteninhalte / Texte",
      "description": "Weitere Texte für Dozenten-Profile, Events und Zertifikate.",
      "settings": {
        "tutors_section_title": {
          "label": "Dozenten-Sektion Titel",
          "type": "text",
          "default": "Unsere Experten-Dozenten",
          "description": "Überschrift der Dozenten-Übersicht"
        },
        "events_section_title": {
          "label": "Seminare & Events Titel",
          "type": "text",
          "default": "Live-Seminare & Webinare",
          "description": "Überschrift der Veranstaltungs-Sektion"
        },
        "certificates_section_title": {
          "label": "Zertifikate-Sektion Titel",
          "type": "text",
          "default": "Anerkannte Zertifizierungen",
          "description": "Überschrift der Zertifikat-Übersicht"
        },
        "testimonials_section_title": {
          "label": "Erfahrungsberichte Titel",
          "type": "text",
          "default": "Was unsere Absolventen sagen",
          "description": "Überschrift der Testimonials-Sektion"
        },
        "cta_section_title": {
          "label": "CTA-Sektion Titel",
          "type": "text",
          "default": "Starte Deine Weiterbildung heute",
          "description": "Überschrift des CTA-Bereichs"
        },
        "cta_section_text": {
          "label": "CTA-Sektion Text",
          "type": "textarea",
          "default": "Registriere Dich kostenlos und erhalte sofortigen Zugang zu ausgewählten Gratis-Kursen sowie 7 Tagen Premium-Test.",
          "description": "Text im CTA-Bereich"
        },
        "subscription_cta_label": {
          "label": "Abo-CTA Label",
          "type": "text",
          "default": "Premium 7 Tage gratis testen",
          "description": "Text des Abonnement-CTA Buttons"
        }
      }
    },

    "advanced": {
      "label": "Erweitert",
      "description": "Custom CSS und LMS-Einstellungen.",
      "settings": {
        "custom_css": {
          "label": "Eigenes CSS",
          "type": "textarea",
          "default": "",
          "description": "Zusätzliches CSS das am Ende angehängt wird."
        },
        "enable_dark_mode_toggle": {
          "label": "Dark-Mode Toggle",
          "type": "checkbox",
          "default": true,
          "description": "Manueller Dark/Light-Mode Wechsel – gut für abendliches Lernen"
        },
        "enable_gamification": {
          "label": "Gamification aktivieren",
          "type": "checkbox",
          "default": false,
          "description": "Punkte, Abzeichen und Bestenlisten für Lernmotivation (erfordert Plugin)"
        }
      }
    }

  }
}
