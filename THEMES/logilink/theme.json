{
  "name": "LogiLink",
  "slug": "logilink",
  "version": "1.0.0",
  "author": "PHINIT.DE / Andreas Hepp",
  "description": "Logistik & Transport Theme – Schnell, präzise, international. Für Speditionen, Kurierdienste und Logistik-Dienstleister.",
  "tags": ["logistik", "transport", "tracking", "dashboard", "responsive", "cms"],
  "supports": ["dark-mode", "custom-logo", "sticky-header", "custom-css", "tracking", "live-map", "status-stepper"],

  "customization": {

    "colors": {
      "label": "Farben",
      "description": "Operative Farbpalette mit aussagekräftigem Status-System für Echtzeit-Tracking.",
      "settings": {
        "primary_color": {
          "label": "Primärfarbe",
          "type": "color",
          "default": "#0284c7",
          "description": "Sky Blue – Hauptfarbe für Effizienz und Klarheit"
        },
        "secondary_color": {
          "label": "Sekundärfarbe",
          "type": "color",
          "default": "#0369a1",
          "description": "Dunkleres Blau für Hover-Zustände"
        },
        "accent_color": {
          "label": "Akzentfarbe",
          "type": "color",
          "default": "#f59e0b",
          "description": "Amber für Warnungen und Prioritäts-Highlights"
        },
        "dark_bg_color": {
          "label": "Dashboard-Dunkel-Hintergrund",
          "type": "color",
          "default": "#0c1a2e",
          "description": "Nacht-Blau für Dashboard- und Monitoring-Ansichten"
        },
        "status_warehouse": {
          "label": "Status: Eingelagert",
          "type": "color",
          "default": "#94a3b8",
          "description": "Grau – Ware im Lager"
        },
        "status_picked": {
          "label": "Status: Kommissioniert",
          "type": "color",
          "default": "#f59e0b",
          "description": "Amber – Ware wird kommissioniert"
        },
        "status_transit": {
          "label": "Status: In Transit",
          "type": "color",
          "default": "#8b5cf6",
          "description": "Violet – Ware in Zustellung"
        },
        "status_delivered": {
          "label": "Status: Geliefert",
          "type": "color",
          "default": "#16a34a",
          "description": "Grün – erfolgreich geliefert"
        },
        "status_delayed": {
          "label": "Status: Verzögert",
          "type": "color",
          "default": "#ef4444",
          "description": "Rot – Lieferverzug"
        },
        "status_returned": {
          "label": "Status: Retoure",
          "type": "color",
          "default": "#64748b",
          "description": "Blau-Grau – Rücksendung"
        },
        "text_color": {
          "label": "Textfarbe",
          "type": "color",
          "default": "#0f172a",
          "description": "Haupttextfarbe"
        },
        "bg_color": {
          "label": "Hintergrundfarbe",
          "type": "color",
          "default": "#f0f9ff",
          "description": "Leicht bläulicher Hintergrund"
        },
        "card_bg_color": {
          "label": "Card-Hintergrundfarbe",
          "type": "color",
          "default": "#ffffff",
          "description": "Hintergrund für Sendungs- und KPI-Cards"
        },
        "muted_color": {
          "label": "Gedämpfte Textfarbe",
          "type": "color",
          "default": "#64748b",
          "description": "Sekundärer Text"
        },
        "border_color": {
          "label": "Rahmenfarbe",
          "type": "color",
          "default": "#bae6fd",
          "description": "Hellblauer Rahmen"
        }
      }
    },

    "typography": {
      "label": "Typografie",
      "description": "Klare, operative Schriften für schnelle Informationsaufnahme.",
      "settings": {
        "font_family_base": {
          "label": "Basis-Schriftart",
          "type": "select",
          "options": {
            "inter": "Inter (empfohlen – präzise, lesbar)",
            "roboto": "Roboto",
            "open-sans": "Open Sans",
            "lato": "Lato"
          },
          "default": "inter",
          "description": "Schriftart für Fließtext und Dashboard-Elemente"
        },
        "font_family_heading": {
          "label": "Überschriften-Schriftart",
          "type": "select",
          "options": {
            "roboto-condensed": "Roboto Condensed (empfohlen – kompakt, operativ)",
            "inter": "Inter",
            "montserrat": "Montserrat",
            "barlow-condensed": "Barlow Condensed"
          },
          "default": "roboto-condensed",
          "description": "Kompakte Schrift für Dashboards und Berichte"
        },
        "font_family_data": {
          "label": "Daten/Tracking-Schriftart",
          "type": "select",
          "options": {
            "jetbrains-mono": "JetBrains Mono (empfohlen – präzise für IDs)",
            "roboto-mono": "Roboto Mono",
            "fira-code": "Fira Code",
            "monospace": "System Monospace"
          },
          "default": "jetbrains-mono",
          "description": "Monospace-Schrift für Sendungsnummern und IDs"
        },
        "font_size_base": {
          "label": "Basis-Schriftgröße (px)",
          "type": "number",
          "default": 15,
          "min": 12,
          "max": 20,
          "description": "Etwas kleiner für datenreiche Dashboard-Ansichten"
        },
        "line_height_base": {
          "label": "Zeilenhöhe",
          "type": "number",
          "default": 1.5,
          "min": 1.2,
          "max": 2.5,
          "step": 0.1
        },
        "font_weight_heading": {
          "label": "Überschriften-Gewicht",
          "type": "select",
          "options": {
            "600": "Semi-Bold (600)",
            "700": "Bold (700) – Standard"
          },
          "default": "700"
        }
      }
    },

    "layout": {
      "label": "Layout",
      "description": "Weites Layout für datenreiche Logistik-Dashboards.",
      "settings": {
        "container_width": {
          "label": "Container-Breite (px)",
          "type": "number",
          "default": 1440,
          "min": 800,
          "max": 1920,
          "description": "Breiteres Layout für KPI-Dashboards und Tabellen"
        },
        "content_padding": {
          "label": "Content-Padding (rem)",
          "type": "number",
          "default": 1.5,
          "min": 0.5,
          "max": 6,
          "step": 0.25
        },
        "border_radius": {
          "label": "Eckenradius (px)",
          "type": "number",
          "default": 6,
          "min": 0,
          "max": 16
        },
        "section_spacing": {
          "label": "Sektionsabstand (rem)",
          "type": "number",
          "default": 3,
          "min": 1,
          "max": 12,
          "step": 0.5
        },
        "enable_sticky_header": {
          "label": "Sticky Header",
          "type": "checkbox",
          "default": true
        },
        "enable_dashboard_mode": {
          "label": "Dashboard-Modus aktivieren",
          "type": "checkbox",
          "default": true,
          "description": "Kompakte, datendichte Ansicht für operative Dashboards"
        },
        "kpi_columns": {
          "label": "KPI-Dashboard Spalten",
          "type": "select",
          "options": {
            "2": "2 Spalten",
            "3": "3 Spalten",
            "4": "4 Spalten – Standard"
          },
          "default": "4",
          "description": "Anzahl KPI-Kacheln pro Reihe"
        }
      }
    },

    "header": {
      "label": "Header",
      "description": "Kompakter, operativer Header mit schnellem Tracking-Zugriff.",
      "settings": {
        "logo_url": {
          "label": "Header Logo",
          "type": "image",
          "default": "",
          "description": "Firmenlogo im Header"
        },
        "header_bg_color": {
          "label": "Header-Hintergrund",
          "type": "color",
          "default": "#0c1a2e",
          "description": "Dunkles Nacht-Blau für operativen Look"
        },
        "header_text_color": {
          "label": "Header-Textfarbe",
          "type": "color",
          "default": "#e0f2fe",
          "description": "Helles Blau-Weiß für Navigation"
        },
        "header_height": {
          "label": "Header-Höhe (px)",
          "type": "number",
          "default": 64,
          "min": 48,
          "max": 100,
          "description": "Kompakter Header für mehr Content-Platz"
        },
        "logo_max_height": {
          "label": "Logo-Maximalhöhe (px)",
          "type": "number",
          "default": 38,
          "min": 24,
          "max": 100
        },
        "show_tracking_quick_search": {
          "label": "Tracking-Schnellsuche im Header",
          "type": "checkbox",
          "default": true,
          "description": "Sendungsnummer-Eingabe direkt im Header-Bereich"
        },
        "tracking_placeholder": {
          "label": "Tracking-Suchfeld Platzhalter",
          "type": "text",
          "default": "Sendungsnummer eingeben...",
          "description": "Platzhaltertext im Tracking-Suchfeld"
        }
      }
    },

    "footer": {
      "label": "Footer",
      "description": "Footer mit Service-Informationen und internationalem Fokus.",
      "settings": {
        "footer_bg_color": {
          "label": "Footer-Hintergrund",
          "type": "color",
          "default": "#0c1a2e",
          "description": "Dunkles Nacht-Blau passend zum Header"
        },
        "footer_text_color": {
          "label": "Footer-Textfarbe",
          "type": "color",
          "default": "#94a3b8",
          "description": "Blau-Grau für Footer-Text"
        },
        "footer_link_color": {
          "label": "Footer-Linkfarbe",
          "type": "color",
          "default": "#bae6fd",
          "description": "Hellblau für Footer-Links"
        },
        "footer_text": {
          "label": "Footer-Beschreibung",
          "type": "textarea",
          "default": "Schnelle, zuverlässige Logistiklösungen für nationale und internationale Sendungen. Ihr Partner für Transport, Lagerung und Last-Mile-Delivery.",
          "description": "Firmenbeschreibung im Footer"
        },
        "copyright_text": {
          "label": "Copyright-Text",
          "type": "text",
          "default": "&copy; {year} {site_title}. Alle Rechte vorbehalten.",
          "description": "Copyright-Zeile. Platzhalter: {year}, {site_title}"
        }
      }
    },

    "buttons": {
      "label": "Buttons",
      "description": "Operative, klare Buttons – schnelle Interaktion zählt.",
      "settings": {
        "button_border_radius": {
          "label": "Button-Eckenradius (px)",
          "type": "number",
          "default": 5,
          "min": 0,
          "max": 50
        },
        "button_padding_x": {
          "label": "Button-Padding horizontal (rem)",
          "type": "number",
          "default": 1.5,
          "min": 0.5,
          "max": 4,
          "step": 0.25
        },
        "button_padding_y": {
          "label": "Button-Padding vertikal (rem)",
          "type": "number",
          "default": 0.625,
          "min": 0.25,
          "max": 2,
          "step": 0.125
        },
        "button_font_weight": {
          "label": "Button-Schriftgewicht",
          "type": "select",
          "options": {
            "600": "Semi-Bold (600) – Standard",
            "700": "Bold (700)"
          },
          "default": "600"
        },
        "button_transform": {
          "label": "Button-Text",
          "type": "select",
          "options": {
            "none": "Normal – Standard",
            "uppercase": "GROSSBUCHSTABEN"
          },
          "default": "none"
        }
      }
    },

    "logistics_hero": {
      "label": "Hero-Bereich",
      "description": "Texte für den Startseiten-Hero (Spediteur-Profil oder Tracking-Einstieg).",
      "settings": {
        "hero_badge": {
          "label": "Hero Badge",
          "type": "text",
          "default": "🚛 Logistik-Netzwerk",
          "description": "Badge-Text über dem Haupttitel"
        },
        "hero_headline": {
          "label": "Hero Hauptüberschrift",
          "type": "text",
          "default": "Sendungen verfolgen. Kapazitäten buchen. Netzwerk wachsen.",
          "description": "Haupttitel des Hero-Bereichs"
        },
        "hero_subline": {
          "label": "Hero Untertitel",
          "type": "textarea",
          "default": "Das digitale Logistik-Netzwerk für Speditionen, Kurierdienste und Lagerdienstleister. Echtzeitstatus, Direktbuchung, KPI-Tracking.",
          "description": "Beschreibungstext im Hero-Bereich"
        },
        "hero_cta_label": {
          "label": "CTA Button Text",
          "type": "text",
          "default": "Kapazitäten buchen",
          "description": "Text des Haupt-CTA-Buttons"
        },
        "hero_tracking_cta_label": {
          "label": "Tracking CTA Button Text",
          "type": "text",
          "default": "Sendung verfolgen",
          "description": "Text des Tracking-CTA-Buttons"
        }
      }
    },

    "logistics_tracking": {
      "label": "Tracking & Status",
      "description": "Bezeichnungen für das Sendungs-Status-System.",
      "settings": {
        "tracking_section_title": {
          "label": "Tracking-Sektion Titel",
          "type": "text",
          "default": "Sendungsverfolgung",
          "description": "Überschrift des Tracking-Bereichs"
        },
        "status_label_warehouse": {
          "label": "Status-Label: Eingelagert",
          "type": "text",
          "default": "Eingelagert",
          "description": "Anzeigetext für Lager-Status"
        },
        "status_label_picked": {
          "label": "Status-Label: Kommissioniert",
          "type": "text",
          "default": "Kommissioniert",
          "description": "Anzeigetext für Kommissionierungs-Status"
        },
        "status_label_transit": {
          "label": "Status-Label: In Transit",
          "type": "text",
          "default": "In Zustellung",
          "description": "Anzeigetext für Transit-Status"
        },
        "status_label_delivered": {
          "label": "Status-Label: Geliefert",
          "type": "text",
          "default": "Erfolgreich zugestellt",
          "description": "Anzeigetext für Geliefert-Status"
        },
        "status_label_delayed": {
          "label": "Status-Label: Verzögerung",
          "type": "text",
          "default": "Verzögerung",
          "description": "Anzeigetext für Verzögerungs-Status"
        },
        "status_label_returned": {
          "label": "Status-Label: Retoure",
          "type": "text",
          "default": "Retoure in Bearbeitung",
          "description": "Anzeigetext für Retoure-Status"
        },
        "tracking_no_result_text": {
          "label": "Tracking: Kein Ergebnis Text",
          "type": "text",
          "default": "Keine Sendung zu dieser Nummer gefunden.",
          "description": "Text wenn keine Sendung gefunden wurde"
        }
      }
    },

    "logistics_content": {
      "label": "Seiteninhalte / Texte",
      "description": "Texte für Service-Seiten, KPI-Dashboard und Buchungsformulare.",
      "settings": {
        "services_section_title": {
          "label": "Services-Sektion Titel",
          "type": "text",
          "default": "Unsere Logistik-Dienstleistungen",
          "description": "Überschrift der Service-Übersicht"
        },
        "capacity_booking_title": {
          "label": "Kapazitätsbuchung Titel",
          "type": "text",
          "default": "Kapazität buchen",
          "description": "Titel des Buchungsformulars"
        },
        "capacity_units_label": {
          "label": "Kapazitäts-Einheiten Label",
          "type": "text",
          "default": "Paletten / Gewicht (kg) / m³",
          "description": "Einheiten-Beschriftung im Buchungsformular"
        },
        "kpi_punctuality_label": {
          "label": "KPI: Pünktlichkeitsrate Label",
          "type": "text",
          "default": "Pünktlichkeitsrate",
          "description": "Bezeichnung der Pünktlichkeitsrate im Dashboard"
        },
        "kpi_efficiency_label": {
          "label": "KPI: Effizienz Label",
          "type": "text",
          "default": "Last-Mile-Effizienz",
          "description": "Bezeichnung der Last-Mile-Effizienz"
        },
        "kpi_damage_label": {
          "label": "KPI: Schadensquote Label",
          "type": "text",
          "default": "Schadensquote",
          "description": "Bezeichnung der Schadensquote"
        },
        "network_section_title": {
          "label": "Netzwerk-Sektion Titel",
          "type": "text",
          "default": "Logistik-Partner im Netzwerk",
          "description": "Überschrift der Partnerliste"
        },
        "cta_section_title": {
          "label": "CTA-Sektion Titel",
          "type": "text",
          "default": "Werde Teil des Netzwerks",
          "description": "Überschrift des Registrierungs-CTA"
        },
        "cta_section_text": {
          "label": "CTA-Sektion Text",
          "type": "textarea",
          "default": "Registriere dein Logistik-Unternehmen und erhalte Zugang zu tausenden Buchungsanfragen täglich.",
          "description": "Beschreibungstext im CTA-Bereich"
        }
      }
    },

    "advanced": {
      "label": "Erweitert",
      "description": "Custom CSS und technische Einstellungen.",
      "settings": {
        "custom_css": {
          "label": "Eigenes CSS",
          "type": "textarea",
          "default": "",
          "description": "Zusätzliches CSS das am Ende angehängt wird."
        },
        "enable_live_map": {
          "label": "Live-Karte aktivieren",
          "type": "checkbox",
          "default": false,
          "description": "Fahrzeug-Tracking auf OpenStreetMap-Karte (erfordert API-Integration)"
        }
      }
    }

  }
}
