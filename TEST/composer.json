{
    "name": "ps-easyit/365cms",
    "description": "365CMS – Modulares PHP-CMS mit Plugin- und Theme-System",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-hash": "*",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.8",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "CMS\\": "core/",
            "CMS\\Services\\": "core/Services/",
            "CMS\\Member\\": "core/Member/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CMS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox",
        "lint": "vendor/bin/phpcs --standard=PSR12 core/ admin/ member/ includes/",
        "analyse": "vendor/bin/phpstan analyse core/ --level=5",
        "check-all": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "PHPUnit-Testsuite ausführen",
        "lint": "PSR-12-Code-Style prüfen",
        "analyse": "PHPStan statische Analyse (Level 5)",
        "check-all": "Alle Qualitätschecks ausführen (lint + analyse + test)"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "extra": {
        "cms-version": "2.0.0",
        "schema-version": 6
    }
}
