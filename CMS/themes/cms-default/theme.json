{
  "name": "Meridian CMS Default",
  "slug": "cms-default",
  "version": "1.1.0",
  "author": "PHINIT.DE / Andreas Hepp",
  "description": "Das offizielle CMS-Default Theme – editorial, klar, charakterstark. Warm Off-White + Near-Black + Deep Amber. Ideal für Blogs, Magazine und Wissensportale.",
  "tags": ["editorial", "magazine", "blog", "responsive", "cms", "default"],
  "supports": ["custom-logo", "sticky-header", "custom-css", "categories", "member-area", "theme-customizer-hooks"],

  "menus": {
    "primary":   "Hauptmenü (Header)",
    "secondary": "Sekundäres Menü (unter Header)",
    "mobile":    "Mobiles Menü (Hamburger)",
    "footer":    "Footer-Navigation"
  },

  "templates": {
    "home":            "home.php",
    "blog":            "blog.php",
    "blog-single":     "blog-single.php",
    "page":            "page.php",
    "category":        "category.php",
    "tag":             "tag.php",
    "author":          "author.php",
    "archive":         "archive.php",
    "search":          "search.php",
    "login":           "login.php",
    "register":        "register.php",
    "forgot-password": "forgot-password.php",
    "contact":         "contact.php",
    "404":             "404.php",
    "error":           "error.php"
  },

  "partials": {
    "header":       "header.php",
    "footer":       "footer.php",
    "sidebar":      "partials/sidebar.php",
    "newsletter":   "partials/newsletter.php",
    "blog-list":    "partials/blog-list-cards.php",
    "blog-grid":    "partials/blog-grid-cards.php"
  },

  "customization": {

    "header": {
      "label": "Header & Logo",
      "description": "Logo, Wordmark, Buttons und Header-Optionen.",
      "settings": {
        "logo_url": {
          "label": "Logo-Bild URL",
          "type": "image",
          "default": "",
          "description": "Logo-Bild (PNG, SVG, WebP). Leer = Text-Wordmark."
        },
        "logo_type": {
          "label": "Logo Typ",
          "type": "select",
          "default": "text",
          "description": "text = nur Wordmark-Text, image = Bild-Logo"
        },
        "logo_text": {
          "label": "Wordmark-Text",
          "type": "text",
          "default": "",
          "description": "Text des Logo-Wordmarks wenn kein Bild gesetzt. Leer = Site-Name."
        },
        "logo_tagline": {
          "label": "Logo-Tagline",
          "type": "text",
          "default": "",
          "description": "Kleine Tagline rechts neben dem Logo. Leer = ausgeblendet."
        },
        "logo_height": {
          "label": "Logo Höhe (px)",
          "type": "number",
          "default": 40,
          "min": 20,
          "max": 120,
          "description": "Maximale Höhe des Logo-Bilds in Pixeln"
        },
        "header_title": {
          "label": "Titel rechts neben Logo",
          "type": "text",
          "default": "",
          "description": "Optionaler Seitentitel rechts neben dem Logo"
        },
        "show_search_btn": {
          "label": "Such-Button anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Icon-Button im Header-Aktionsbereich"
        },
        "show_login_btn": {
          "label": "Anmelden-Button anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Login-Button im Header anzeigen"
        },
        "show_register_btn": {
          "label": "Registrieren-Button anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Registrieren-Button im Header anzeigen"
        },
        "header_stripe_enabled": {
          "label": "Akzentstreifen oben anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Der farbige 3px-Streifen ganz oben am Header"
        }
      }
    },

    "navigation": {
      "label": "Navigation",
      "description": "Untermenü, Kategorie-Leiste und mobiles Menü.",
      "settings": {
        "header_bar_mode": {
          "label": "Leiste unter Header",
          "type": "select",
          "default": "categories",
          "description": "none = aus, categories = Kategorien automatisch, menu = Sekundäres Menü"
        },
        "mobile_menu_enabled": {
          "label": "Mobiles Menü (Hamburger) aktivieren",
          "type": "checkbox",
          "default": true,
          "description": "Hamburger-Menü auf kleinen Bildschirmen anzeigen"
        },
        "nav_font_size": {
          "label": "Navigation Schriftgröße (px)",
          "type": "number",
          "default": 14,
          "min": 11,
          "max": 20,
          "description": "Schriftgröße der Hauptmenü-Links"
        },
        "nav_uppercase": {
          "label": "Navigation in Großbuchstaben",
          "type": "checkbox",
          "default": false,
          "description": "Menü-Links in Kapitälchen/Großbuchstaben anzeigen"
        },
        "nav_letter_spacing": {
          "label": "Navigation Buchstabenabstand",
          "type": "text",
          "default": "0",
          "description": "CSS letter-spacing für Menü-Links, z.B. 0.05em"
        }
      }
    },

    "layout": {
      "label": "Layout",
      "description": "Containerbreite, Sidebar, Spalten und Abstände.",
      "settings": {
        "max_width": {
          "label": "Maximale Seitenbreite (px)",
          "type": "number",
          "default": 1140,
          "min": 800,
          "max": 1600,
          "description": "Maximale Breite des Inhaltsbereichs"
        },
        "show_sidebar": {
          "label": "Sidebar anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Zeigt die rechte Sidebar auf Blog- und Startseite an"
        },
        "show_category_bar": {
          "label": "Kategorie-Leiste anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Navigationsleiste mit Kategorien unterhalb des Headers"
        },
        "sticky_header": {
          "label": "Sticky Header",
          "type": "checkbox",
          "default": true,
          "description": "Header bleibt beim Scrollen oben fixiert"
        },
        "content_layout": {
          "label": "Inhalts-Layout",
          "type": "select",
          "default": "with_sidebar",
          "description": "with_sidebar = Haupt + Seitenleiste, full_width = volle Breite"
        },
        "post_col_width": {
          "label": "Text-Spaltenbreite (px)",
          "type": "number",
          "default": 680,
          "min": 300,
          "max": 1200,
          "description": "Maximale Breite des Haupt-Textbereichs"
        },
        "border_radius": {
          "label": "Eck-Radius (px)",
          "type": "number",
          "default": 3,
          "min": 0,
          "max": 24,
          "description": "Abrundung von Karten, Buttons und Eingabefeldern"
        },
        "card_gap": {
          "label": "Karten-Abstand (px)",
          "type": "number",
          "default": 24,
          "min": 4,
          "max": 64,
          "description": "Abstand zwischen Grid-Karten und Artikel-Elementen"
        },
        "show_back_to_top": {
          "label": "Zurück-nach-oben-Button anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Schwebendes Icon zum Zurückspringen an den Seitenanfang"
        }
      }
    },

    "colors": {
      "label": "Farben",
      "description": "Globale Farbpalette – Typografie, Akzent und Hintergrundfarben.",
      "settings": {
        "accent_color": {
          "label": "Akzentfarbe (Haupt-Highlight)",
          "type": "color",
          "default": "#c0862a",
          "description": "Hauptakzentfarbe für Links, Hover-Effekte, Badges und Highlights"
        },
        "accent_dark_color": {
          "label": "Akzentfarbe Hover/Dunkel",
          "type": "color",
          "default": "#a06b18",
          "description": "Wird bei Hover-Effekten verwendet"
        },
        "ink_color": {
          "label": "Textfarbe (Primär)",
          "type": "color",
          "default": "#1a1a18",
          "description": "Hauptfarbe für Überschriften und Body-Text"
        },
        "ink_soft_color": {
          "label": "Textfarbe (Weich)",
          "type": "color",
          "default": "#3d3d3a",
          "description": "Für sekundäre Texte, Nav-Items"
        },
        "ink_muted_color": {
          "label": "Textfarbe (Gedämpft)",
          "type": "color",
          "default": "#7a7a74",
          "description": "Für Meta-Infos, Datumsangaben, Labels"
        },
        "ground_color": {
          "label": "Seiten-Hintergrundfarbe",
          "type": "color",
          "default": "#f7f6f2",
          "description": "Warmes Off-White als Grundfarbe der Seite"
        },
        "surface_color": {
          "label": "Karten-/Flächen-Farbe",
          "type": "color",
          "default": "#ffffff",
          "description": "Hintergrundfarbe für Cards, Header und Modals"
        },
        "surface_tint_color": {
          "label": "Surface Tint",
          "type": "color",
          "default": "#f2f1ec",
          "description": "Leicht getönter Hintergrund für Tabellenköpfe etc."
        },
        "rule_color": {
          "label": "Trennlinien-Farbe",
          "type": "color",
          "default": "#e2e0d8",
          "description": "Linien zwischen Elementen, Rahmen"
        },
        "header_bg_color": {
          "label": "Header-Hintergrundfarbe",
          "type": "color",
          "default": "#ffffff",
          "description": "Hintergrundfarbe des Site-Headers"
        },
        "header_stripe_color": {
          "label": "Header-Akzentstreifen Farbe",
          "type": "color",
          "default": "#1a1a18",
          "description": "Der dünne farbige Streifen ganz oben am Header"
        },
        "link_color": {
          "label": "Link-Farbe (Content)",
          "type": "color",
          "default": "#c0862a",
          "description": "Textfarbe für Hyperlinks im Content-Bereich"
        },
        "link_hover_color": {
          "label": "Link Hover-Farbe",
          "type": "color",
          "default": "#a06b18",
          "description": "Link-Farbe beim Überfahren mit der Maus"
        },
        "category_bar_bg": {
          "label": "Kategorie-Leiste Hintergrundfarbe",
          "type": "color",
          "default": "#f2f1ec",
          "description": "Hintergrundfarbe der Kategorie-/Menüleiste unter dem Header"
        },
        "category_bar_text": {
          "label": "Kategorie-Leiste Textfarbe",
          "type": "color",
          "default": "#3d3d3a",
          "description": "Textfarbe der Links in der Kategorie-Leiste"
        }
      }
    },

    "typography": {
      "label": "Typografie",
      "description": "Schriftgrößen, Zeilenhöhe und Überschriftengewicht.",
      "settings": {
        "google_fonts": {
          "label": "Google Fonts laden",
          "type": "checkbox",
          "default": true,
          "description": "Lädt Libre Baskerville und DM Sans von Google Fonts"
        },
        "font_size_base": {
          "label": "Basis-Schriftgröße (px)",
          "type": "number",
          "default": 15,
          "min": 12,
          "max": 22,
          "description": "Basis-Schriftgröße des Fließtexts in Pixeln"
        },
        "line_height": {
          "label": "Zeilenhöhe",
          "type": "text",
          "default": "1.6",
          "description": "Zeilenhöhe als Dezimalwert, z. B. 1.6"
        },
        "heading_weight": {
          "label": "Überschriften Schriftstärke",
          "type": "select",
          "default": "700",
          "description": "Schriftgewicht für h1–h6"
        },
        "font_family_body": {
          "label": "Schriftart Fließtext",
          "type": "select",
          "default": "dm-sans",
          "description": "dm-sans = DM Sans, system-ui = System-Schrift, georgia = Georgia, inter = Inter"
        },
        "font_family_heading": {
          "label": "Schriftart Überschriften",
          "type": "select",
          "default": "libre-baskerville",
          "description": "libre-baskerville = Libre Baskerville, georgia = Georgia, playfair-display = Playfair Display, system-ui = System-Schrift"
        },
        "letter_spacing_headings": {
          "label": "Buchstabenabstand Überschriften",
          "type": "text",
          "default": "0",
          "description": "CSS letter-spacing, z.B. -0.02em, 0.05em oder 0"
        },
        "h1_size": {
          "label": "H1 Schriftgröße (px)",
          "type": "number",
          "default": 38,
          "min": 18,
          "max": 72,
          "description": "Schriftgröße der H1-Überschrift in Pixeln"
        },
        "h2_size": {
          "label": "H2 Schriftgröße (px)",
          "type": "number",
          "default": 28,
          "min": 14,
          "max": 60,
          "description": "Schriftgröße der H2-Überschrift in Pixeln"
        },
        "h3_size": {
          "label": "H3 Schriftgröße (px)",
          "type": "number",
          "default": 22,
          "min": 12,
          "max": 48,
          "description": "Schriftgröße der H3-Überschrift in Pixeln"
        }
      }
    },

    "footer": {
      "label": "Footer",
      "description": "Footer-Inhalt, Spalten, Social Icons und Copyright.",
      "settings": {
        "footer_description": {
          "label": "Footer-Beschreibung",
          "type": "textarea",
          "default": "Praxisnahe Guides, Tutorials und Wissen für IT-Profis und technisch interessierte Leser.",
          "description": "Kurzbeschreibung im ersten Footer-Abschnitt"
        },
        "col1_title": {
          "label": "Spalte 1 – Titel",
          "type": "text",
          "default": "Rubriken",
          "description": "Überschrift der ersten Linksspalte im Footer"
        },
        "col2_title": {
          "label": "Spalte 2 – Titel",
          "type": "text",
          "default": "Ressourcen",
          "description": "Überschrift der zweiten Linksspalte im Footer"
        },
        "col3_title": {
          "label": "Spalte 3 – Titel",
          "type": "text",
          "default": "Über",
          "description": "Überschrift der dritten Linksspalte im Footer"
        },
        "footer_bg_color": {
          "label": "Footer Hintergrundfarbe",
          "type": "color",
          "default": "#1a1a18",
          "description": "Hintergrundfarbe des Footer-Bereichs"
        },
        "footer_text_color": {
          "label": "Footer Textfarbe",
          "type": "color",
          "default": "#9a9a94",
          "description": "Textfarbe im Footer"
        },
        "footer_accent_color": {
          "label": "Footer Link-Farbe",
          "type": "color",
          "default": "#c0862a",
          "description": "Farbe für Links und Hover im Footer"
        },
        "copyright_text": {
          "label": "Copyright-Text",
          "type": "text",
          "default": "© {year} {site_title}. Alle Rechte vorbehalten.",
          "description": "Platzhalter: {year}, {site_title}"
        },
        "show_social_icons": {
          "label": "Social-Icons anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Social-Media-Icons im Footer-Bereich anzeigen"
        },
        "social_twitter": {
          "label": "Twitter / X URL",
          "type": "text",
          "default": "",
          "description": "Vollständige URL z. B. https://x.com/username"
        },
        "social_instagram": {
          "label": "Instagram URL",
          "type": "text",
          "default": "",
          "description": "Vollständige URL"
        },
        "social_linkedin": {
          "label": "LinkedIn URL",
          "type": "text",
          "default": "",
          "description": "Vollständige URL"
        },
        "social_youtube": {
          "label": "YouTube URL",
          "type": "text",
          "default": "",
          "description": "Vollständige URL"
        }
      }
    },

    "blog": {
      "label": "Blog & Artikel",
      "description": "Darstellung der Artikelliste und einzelner Posts.",
      "settings": {
        "posts_per_page": {
          "label": "Artikel pro Seite",
          "type": "number",
          "default": 12,
          "min": 4,
          "max": 50,
          "description": "Anzahl der Artikel auf der Blog-Übersichtsseite"
        },
        "show_hero_post": {
          "label": "Hero-Post anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Das neueste Artikel als großes Hero-Element oben darstellen"
        },
        "show_reading_time": {
          "label": "Lesezeit anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Geschätzte Lesezeit bei Artikeln anzeigen"
        },
        "show_author": {
          "label": "Autor anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Autorenname in der Artikel-Meta-Zeile anzeigen"
        },
        "show_views": {
          "label": "Aufrufe anzeigen",
          "type": "checkbox",
          "default": false,
          "description": "Aufruf-Zähler bei Artikeln anzeigen"
        },
        "show_comments": {
          "label": "Kommentarformular anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Kommentarformular unterhalb von Blog-Artikeln anzeigen"
        },
        "show_related_posts": {
          "label": "Verwandte Artikel anzeigen",
          "type": "checkbox",
          "default": true,
          "description": "Ähnliche Artikel am Ende eines Blog-Posts zeigen"
        }
      }
    },

    "homepage": {
      "label": "Startseite",
      "description": "Verhalten und Inhalt der Startseite.",
      "settings": {
        "homepage_mode": {
          "label": "Startseiten-Modus",
