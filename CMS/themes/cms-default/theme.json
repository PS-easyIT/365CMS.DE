        },
        "homepage_cta_url": {
          "label": "CTA Button URL",
          "type": "text",
          "default": "",
          "description": "Ziel-URL des CTA-Buttons"
        }
      }
    },

    "advanced": {
      "label": "Erweitert",
      "description": "Eigenes CSS, Head Code und Footer Code.",
      "settings": {
        "custom_css": {
          "label": "Eigenes CSS",
          "type": "textarea",
