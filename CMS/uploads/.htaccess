Options -Indexes
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Content-Disposition "attachment"
</IfModule>
<FilesMatch "\.(avif|bmp|gif|ico|jpe?g|png|webp)$">
    <IfModule mod_headers.c>
        Header always unset Content-Disposition
        Header always set Content-Disposition "inline"
    </IfModule>
</FilesMatch>
<FilesMatch "\.(php|php3|php4|php5|phtml|phar|cgi|pl|py|sh)$">
    Require all denied
</FilesMatch>
Options -ExecCGI
